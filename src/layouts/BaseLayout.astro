---
import '../styles/global.css';
import { appearanceMap, defaultVariantId } from '../data/appearance';
import { contactLinks } from '../data/contact';
import { identity } from '../data/identity';

type Props = {
  title?: string;
  description?: string;
};

const { title = `${identity.name} — ${identity.title}`, description = identity.description } =
  Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: identity.name,
  jobTitle: identity.title,
  worksFor: { '@type': 'Organization', name: identity.company },
  address: { '@type': 'PostalAddress', addressLocality: 'Budapest', addressCountry: 'HU' },
  url: Astro.site?.href,
  sameAs: contactLinks.filter((link) => link.external).map((link) => link.href),
};
---

<!doctype html>
<html lang="en" data-variant="editorial" data-tone="paper" data-scheme-choice="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline define:vars={{ appearanceMap, defaultVariantId }}>
      (() => {
        const storedVariant = localStorage.getItem('appearance:variant');
        const variantId = appearanceMap[storedVariant] ? storedVariant : defaultVariantId;
        const config = appearanceMap[variantId];
        const storedScheme = localStorage.getItem('appearance:scheme');
        const schemeChoice = storedScheme === 'light' || storedScheme === 'dark' ? storedScheme : 'system';
        const prefersDark = matchMedia('(prefers-color-scheme: dark)').matches;
        const scheme = schemeChoice === 'system' ? (prefersDark ? 'dark' : 'light') : schemeChoice;
        const storedTone = localStorage.getItem(`appearance:tone:${variantId}:${scheme}`);
        const toneId = config[scheme].includes(storedTone) ? storedTone : config[scheme][0];
        const root = document.documentElement;
        root.dataset.variant = variantId;
        root.dataset.tone = toneId;
        root.dataset.schemeChoice = schemeChoice;
        root.classList.toggle('dark', scheme === 'dark');
      })();
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body class="bg-bg font-body text-body text-prose">
    <slot />
  </body>
</html>
