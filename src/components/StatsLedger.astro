---
import { stats } from '../data/stats';
---

<div class="border-y border-rule">
  <dl class="shell grid grid-cols-2 sm:grid-cols-4">
    {
      stats.map((stat) => (
        <div class="flex flex-col py-7 sm:py-9">
          <dd class="order-1 font-display text-[clamp(1.875rem,1.5rem+1.5vw,2.75rem)] leading-none font-semibold text-ink tabular-nums">
            {stat.value}
            {stat.accent && <span class="text-accent">{stat.accent}</span>}
          </dd>
          <dt class="order-2 mt-2 font-mono text-meta tracking-[0.12em] text-muted uppercase">
            {stat.label}
          </dt>
        </div>
      ))
    }
  </dl>
</div>
