---
import { variants } from '../data/appearance';

const schemeOptions = [
  { id: 'light', label: 'Light' },
  { id: 'dark', label: 'Dark' },
  { id: 'system', label: 'System' },
];

const toneGroups = variants.flatMap((variant) =>
  (['light', 'dark'] as const)
    .map((scheme) => ({
      variantId: variant.id,
      scheme,
      tones: variant.tones.filter((tone) => tone.scheme === scheme),
    }))
    .filter((group) => group.tones.length > 1),
);
---

<button
  popovertarget="appearance-popover"
  type="button"
  class="grid size-9 shrink-0 place-items-center text-muted transition-colors hover:text-ink"
  aria-label="Appearance settings"
>
  <svg
    class="size-[18px]"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="3.25"></circle>
    <path
      d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.03 1.56V21a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-1.11-1.56 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.7 1.7 0 0 0 .34-1.87 1.7 1.7 0 0 0-1.56-1.03H3a2 2 0 1 1 0-4h.09a1.7 1.7 0 0 0 1.56-1.11 1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.7 1.7 0 0 0 1.87.34h.08A1.7 1.7 0 0 0 10.12 3.6V3.5a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1.03 1.56 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.7 1.7 0 0 0-.34 1.87v.08a1.7 1.7 0 0 0 1.56 1.03h.1a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-1.56 1.03Z"
    ></path>
  </svg>
</button>

<div
  id="appearance-popover"
  popover
  class="appearance-popover w-[19.5rem] rounded-window border border-rule bg-surface p-5 text-prose shadow-[0_1px_2px_oklch(21%_0.01_95_/_0.06),0_16px_40px_oklch(21%_0.01_95_/_0.12)]"
>
  <p class="font-display text-[15px] font-semibold text-ink">Appearance</p>
  <p class="mt-1 text-[13px] leading-snug text-muted">
    Pick a design and a scheme. Saved in your browser only.
  </p>

  <div class="mt-4 flex flex-col gap-1" role="radiogroup" aria-label="Design variant">
    {
      variants.map((variant) => (
        <button
          type="button"
          role="radio"
          aria-checked="false"
          data-variant-option={variant.id}
          class="variant-option grid grid-cols-[1rem_1fr] items-baseline gap-x-3 rounded-chip px-2 py-2 text-left transition-colors hover:bg-accent-soft/60"
        >
          <span class="radio-dot relative top-[1px] inline-block size-3 rounded-full border border-muted" />
          <span>
            <span class="block text-[14px] font-medium text-ink">{variant.label}</span>
            <span class="block text-[12.5px] leading-snug text-muted">{variant.description}</span>
          </span>
        </button>
      ))
    }
  </div>

  <div
    class="mt-4 flex flex-wrap gap-2 border-t border-rule pt-4"
    role="radiogroup"
    aria-label="Color scheme"
  >
    {
      schemeOptions.map((scheme) => (
        <button
          type="button"
          role="radio"
          aria-checked="false"
          data-scheme-option={scheme.id}
          class="appearance-chip rounded-chip border border-rule px-3 py-1.5 font-mono text-[11.5px] tracking-[0.08em] text-muted uppercase transition-colors hover:text-ink"
        >
          {scheme.label}
        </button>
      ))
    }
  </div>

  {
    toneGroups.map((group) => (
      <div
        data-tone-group={`${group.variantId}:${group.scheme}`}
        class="tone-group mt-3 hidden flex-wrap items-center gap-2"
        role="radiogroup"
        aria-label={`${group.variantId} ${group.scheme} tone`}
      >
        <span class="font-mono text-[10.5px] tracking-[0.12em] text-muted uppercase">tone</span>
        {group.tones.map((tone) => (
          <button
            type="button"
            role="radio"
            aria-checked="false"
            data-tone-option={tone.id}
            class="appearance-chip rounded-chip border border-rule px-3 py-1.5 font-mono text-[11.5px] tracking-[0.08em] text-muted uppercase transition-colors hover:text-ink"
          >
            {tone.label}
          </button>
        ))}
      </div>
    ))
  }

  <div class="mt-4 flex items-center justify-between border-t border-rule pt-4">
    <button
      type="button"
      id="appearance-reset"
      class="font-mono text-[11.5px] tracking-[0.08em] text-muted uppercase transition-colors hover:text-accent"
    >
      Reset to defaults
    </button>
    <span class="font-mono text-[11.5px] text-muted">no cookies</span>
  </div>
</div>

<style>
  .appearance-popover {
    position: fixed;
    inset: unset;
    top: 3.75rem;
    right: max(0.75rem, calc((100vw - 72rem) / 2));
    margin: 0;
  }

  .appearance-popover::backdrop {
    background: transparent;
  }

  .variant-option[aria-checked='true'] .radio-dot {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: inset 0 0 0 2.5px var(--surface);
  }

  .appearance-chip[aria-checked='true'] {
    border-color: var(--accent);
    color: var(--ink);
  }
</style>

<script>
  import { appearanceMap, defaultVariantId, storageKeys } from '../data/appearance';

  type Scheme = 'light' | 'dark';
  type VariantConfig = Record<Scheme, string[]>;

  const root = document.documentElement;
  const media = window.matchMedia('(prefers-color-scheme: dark)');
  const popover = document.getElementById('appearance-popover');

  const configFor = (variantId: string) =>
    (appearanceMap as Record<string, VariantConfig>)[variantId];

  const currentVariant = () => {
    const stored = localStorage.getItem(storageKeys.variant);
    return stored && configFor(stored) ? stored : defaultVariantId;
  };

  const currentSchemeChoice = () => {
    const stored = localStorage.getItem(storageKeys.scheme);
    return stored === 'light' || stored === 'dark' ? stored : 'system';
  };

  const resolveScheme = (choice: string): Scheme =>
    choice === 'system' ? (media.matches ? 'dark' : 'light') : (choice as Scheme);

  const currentTone = (variantId: string, scheme: Scheme) => {
    const tonePool = configFor(variantId)[scheme];
    const stored = localStorage.getItem(storageKeys.tone(variantId, scheme));
    return stored && tonePool.includes(stored) ? stored : tonePool[0];
  };

  const apply = () => {
    const variantId = currentVariant();
    const schemeChoice = currentSchemeChoice();
    const scheme = resolveScheme(schemeChoice);
    const toneId = currentTone(variantId, scheme);
    root.dataset.variant = variantId;
    root.dataset.tone = toneId;
    root.dataset.schemeChoice = schemeChoice;
    root.classList.toggle('dark', scheme === 'dark');
    syncControls(variantId, schemeChoice, scheme, toneId);
  };

  const syncControls = (
    variantId: string,
    schemeChoice: string,
    scheme: Scheme,
    toneId: string | undefined,
  ) => {
    for (const option of document.querySelectorAll<HTMLElement>('[data-variant-option]')) {
      option.setAttribute('aria-checked', String(option.dataset.variantOption === variantId));
    }
    for (const option of document.querySelectorAll<HTMLElement>('[data-scheme-option]')) {
      option.setAttribute('aria-checked', String(option.dataset.schemeOption === schemeChoice));
    }
    const activeGroupId = `${variantId}:${scheme}`;
    for (const group of document.querySelectorAll<HTMLElement>('[data-tone-group]')) {
      const isActive = group.dataset.toneGroup === activeGroupId;
      group.classList.toggle('hidden', !isActive);
      group.classList.toggle('flex', isActive);
      if (!isActive) continue;
      for (const chip of group.querySelectorAll<HTMLElement>('[data-tone-option]')) {
        chip.setAttribute('aria-checked', String(chip.dataset.toneOption === toneId));
      }
    }
  };

  for (const option of document.querySelectorAll<HTMLElement>('[data-variant-option]')) {
    option.addEventListener('click', () => {
      const variantId = option.dataset.variantOption;
      if (!variantId) return;
      localStorage.setItem(storageKeys.variant, variantId);
      apply();
    });
  }

  for (const option of document.querySelectorAll<HTMLElement>('[data-scheme-option]')) {
    option.addEventListener('click', () => {
      const choice = option.dataset.schemeOption;
      if (!choice) return;
      if (choice === 'system') {
        localStorage.removeItem(storageKeys.scheme);
      } else {
        localStorage.setItem(storageKeys.scheme, choice);
      }
      apply();
    });
  }

  for (const group of document.querySelectorAll<HTMLElement>('[data-tone-group]')) {
    const [variantId, scheme] = (group.dataset.toneGroup ?? '').split(':');
    if (!variantId || (scheme !== 'light' && scheme !== 'dark')) continue;
    for (const chip of group.querySelectorAll<HTMLElement>('[data-tone-option]')) {
      chip.addEventListener('click', () => {
        const toneId = chip.dataset.toneOption;
        if (!toneId) return;
        localStorage.setItem(storageKeys.tone(variantId, scheme), toneId);
        apply();
      });
    }
  }

  document.getElementById('appearance-reset')?.addEventListener('click', () => {
    const staleKeys = [];
    for (let index = 0; index < localStorage.length; index += 1) {
      const key = localStorage.key(index);
      if (key?.startsWith('appearance:')) staleKeys.push(key);
    }
    for (const key of staleKeys) {
      localStorage.removeItem(key);
    }
    apply();
  });

  media.addEventListener('change', () => {
    if (currentSchemeChoice() === 'system') apply();
  });

  popover?.addEventListener('toggle', apply);
  apply();
</script>
