---
import { aboutParagraphs, pullQuote } from '../data/about';
import SectionHeading from './SectionHeading.astro';

const [lede, ...rest] = aboutParagraphs;
---

<section id="about" class="shell py-section">
  <SectionHeading number="01" title="About the work." />
  <div class="mt-12 lg:grid lg:grid-cols-[6rem_1fr]">
    <div></div>
    <div class="max-w-[65ch] space-y-6">
      <p
        class="first-letter:float-left first-letter:mt-1 first-letter:pr-3 first-letter:font-display first-letter:text-[4.2em] first-letter:leading-[0.75] first-letter:font-bold first-letter:text-accent"
      >
        {lede}
      </p>
      {rest.slice(0, 1).map((paragraph) => <p>{paragraph}</p>)}
      <blockquote
        class="border-l-2 border-accent py-1 pl-6 font-display text-[1.75rem] leading-[1.3] font-medium text-ink italic"
      >
        {pullQuote}
      </blockquote>
      {rest.slice(1).map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</section>
