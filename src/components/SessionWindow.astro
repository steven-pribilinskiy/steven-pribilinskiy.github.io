---
import { hero } from '../data/hero';

const keyPad =
  Math.max(...hero.sessionLines.map((line) => (line.kind === 'field' ? line.key.length : 0))) + 2;
---

<figure
  class="session-window rounded-window border border-rule bg-surface shadow-[0_1px_2px_oklch(21%_0.01_95_/_0.06),0_16px_40px_oklch(21%_0.01_95_/_0.08)]"
>
  <figcaption class="flex items-center gap-3 border-b border-rule px-4 py-3">
    <span class="flex gap-1.5" aria-hidden="true">
      <span class="size-[9px] rounded-full border border-rule"></span>
      <span class="size-[9px] rounded-full border border-rule"></span>
      <span class="size-[9px] rounded-full border border-rule"></span>
    </span>
    <span class="font-mono text-meta text-muted">{hero.sessionCaption}</span>
  </figcaption>
  <div class="overflow-x-auto px-5 py-5 font-mono text-[13px] leading-[1.8] whitespace-pre">
    {
      hero.sessionLines.map((line) => {
        if (line.kind === 'prompt') {
          return (
            <div>
              <span class="text-signal">❯</span>
              <span class="text-ink"> {line.command}</span>
            </div>
          );
        }
        if (line.kind === 'field') {
          return (
            <div>
              <span class="text-accent">{`${line.key}:`.padEnd(keyPad)}</span>
              <span>{line.value}</span>
              {line.comment && <span class="text-muted">  {line.comment}</span>}
            </div>
          );
        }
        return (
          <div>
            <span class="text-signal">❯ </span>
            <span class="session-caret inline-block h-[1.05em] w-[0.55em] translate-y-[0.15em] bg-prose"></span>
          </div>
        );
      })
    }
  </div>
</figure>

<style is:global>
  .dark .session-window {
    position: relative;
    box-shadow:
      0 0 0 1px var(--rule),
      0 20px 50px oklch(0% 0 0 / 0.5),
      0 8px 60px oklch(70% 0.15 45 / 0.1);
  }
  .dark .session-window::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    border-radius: var(--radius-window) var(--radius-window) 0 0;
    background: linear-gradient(90deg, transparent, oklch(70% 0.15 45 / 0.5), transparent);
  }
</style>
